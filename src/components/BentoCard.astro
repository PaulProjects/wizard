---
import { Icon } from "astro-icon/components";

interface Props {
	title?: string;
	description?: string;
	icon?: string;
	iconColor?: string;
	class?: string;
	tooltip?: string;
	titleClass?: string;
	descClass?: string;
	headerClass?: string;
}

const {
	title,
	description,
	icon,
	iconColor = "text-primary",
	class: className = "flex flex-col p-6",
	tooltip,
	titleClass = "font-bold text-2xl",
	descClass = "text-sm text-base-content/70",
	headerClass = "flex flex-col gap-2 relative z-10 mb-6",
} = Astro.props;
---

<div
	class:list={[
		"bg-base-200/50 rounded-2xl border border-base-content/10 shadow-sm backdrop-blur-md relative",
		className?.includes("group") ? "" : "group",
		tooltip ? "tooltip" : "",
		className,
	]}
	data-tip={tooltip}
>
	{tooltip && (
		<button
			type="button"
			class="absolute right-3 top-3 opacity-50 hover:opacity-100 transition-opacity z-20"
			aria-label="Info"
		>
			<Icon
				name="mdi:information-outline"
				class="h-4 w-4 text-base-content"
			/>
		</button>
	)}

	{(title || icon) && (
		<div class={headerClass}>
			<div class="flex items-center gap-2">
				{icon && <Icon name={icon} class={`w-6 h-6 flex-shrink-0 ${iconColor}`} />}
				{title && <h2 class={titleClass}>{title}</h2>}
			</div>
			{description && <p class={descClass}>{description}</p>}
		</div>
	)}

	<slot />
</div>